{
    "name": "opal-redesign",
    "version": "0.2.0",
    "private": true,
    "description": "Modern UI overlay for the OPAL learning platform",
    "type": "module",
    "scripts": {
        "build": "node esbuild.config.mjs && npx @tailwindcss/cli -i main.css -o styles/modern.css",
        "build:js": "node esbuild.config.mjs",
        "build:css": "npx @tailwindcss/cli -i main.css -o styles/modern.css",
        "dev": "concurrently \"node esbuild.config.mjs --watch\" \"npx @tailwindcss/cli -i main.css -o styles/modern.css --watch\"",
        "dev:js": "node esbuild.config.mjs --watch",
        "dev:css": "npx @tailwindcss/cli -i main.css -o styles/modern.css --watch"
    },
    "devDependencies": {
        "@tailwindcss/cli": "^4.2.0",
        "@tailwindcss/oxide-win32-x64-msvc": "^4.2.0",
        "@types/chrome": "^0.0.300",
        "concurrently": "^9.1.2",
        "esbuild": "^0.25.0",
        "tailwindcss": "^4.0.0",
        "typescript": "^5.7.3"
    },
    "dependencies": {
        "@orama/orama": "^3.1.18",
        "dexie": "^4.3.0",
        "fuse.js": "^7.1.0",
        "gridstack": "^12.4.2"
    }
}
